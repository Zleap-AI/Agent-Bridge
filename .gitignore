# -*- coding: utf-8 -*-
# Go 项目 .gitignore
# Lzm 2026-07-13

# 文档目录（README 图片除外）
docs/*
!docs/logo.svg
!docs/assets/
docs/assets/*
!docs/assets/readme/
docs/assets/readme/*
!docs/assets/readme/*.png

# 编译产物
build/
bin/
dist/
*.exe
bridge.exe~

# Go 缓存
vendor/
__pycache__/
*.pyc

# IDE
.idea/
.vscode/
*.swp
*.swo
.trae/

# 系统
.DS_Store
Thumbs.db

# 日志
*.log

# test
test/
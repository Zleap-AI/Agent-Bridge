{
  "name": "agent-bridge-consoles",
  "private": true,
  "version": "0.4.0",
  "type": "module",
  "scripts": {
    "dev:local": "vite --config vite.local.config.ts",
    "dev:remote": "vite --config vite.remote.config.ts",
    "build": "npm run typecheck && npm run build:local && npm run build:remote",
    "build:local": "vite build --config vite.local.config.ts",
    "build:remote": "vite build --config vite.remote.config.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@vitejs/plugin-react": "6.0.3",
    "lucide-react": "1.24.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "vite": "8.1.4",
    "vite-plugin-singlefile": "2.3.3"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@playwright/test": "1.61.1",
    "@types/node": "26.1.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "jsdom": "29.1.1",
    "typescript": "7.0.2",
    "vitest": "4.1.10"
  }
}
